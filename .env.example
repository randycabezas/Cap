# -----------------------------
# Core App / URLs
# -----------------------------
CAP_URL=https://cap.example.com

# -----------------------------
# MySQL Credentials
# -----------------------------
MYSQL_PASSWORD=your-mysql-password
MYSQL_ROOT_PASSWORD=your-mysql-root-password

# -----------------------------
# App Secrets (generate with: openssl rand -hex 32)
# -----------------------------
DATABASE_ENCRYPTION_KEY=your-64-char-hex-string
NEXTAUTH_SECRET=your-64-char-hex-string
MEDIA_SERVER_WEBHOOK_SECRET=your-64-char-hex-string

# -----------------------------
# Email (Resend — https://resend.com)
# -----------------------------
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_DOMAIN=mail.example.com

# -----------------------------
# S3 / Object Storage (any S3-compatible provider)
# -----------------------------
S3_ACCESS_KEY=your-s3-access-key
S3_SECRET_KEY=your-s3-secret-key

S3_BUCKET=your-bucket-name
S3_REGION=us-east-1

S3_PUBLIC_ENDPOINT=https://s3.us-east-1.amazonaws.com
S3_INTERNAL_ENDPOINT=https://s3.us-east-1.amazonaws.com

# Set to true if your S3 provider requires path-style addressing
S3_PATH_STYLE=false
